      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='E-Commerce KPI ' name='federated.1i1081p0v8bss811an3dm1insuyz' />
          </datasources>
          <datasource-dependencies datasource='federated.1i1081p0v8bss811an3dm1insuyz'>
            <column caption='Average Order Value' datatype='real' name='[Calculation_1231734563289759744]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='Sum([sales])/Count([order_id])' />
            </column>
            <column caption='Profit Margin' datatype='real' name='[Calculation_1231734563290652673]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(sum([profit])/Sum([sales]))*100' />
            </column>
            <column caption='Order Id' datatype='integer' name='[order_id]' role='dimension' type='ordinal' />
            <column caption='Profit' datatype='integer' name='[profit]' role='measure' type='quantitative' />
            <column caption='Sales' datatype='integer' name='[sales]' role='measure' type='quantitative' />
            <column-instance column='[profit]' derivation='Sum' name='[sum:profit:qk]' pivot='key' type='quantitative' />
            <column-instance column='[sales]' derivation='Sum' name='[sum:sales:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1231734563289759744]' derivation='User' name='[usr:Calculation_1231734563289759744:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1231734563290652673]' derivation='User' name='[usr:Calculation_1231734563290652673:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
